# ─────────────────────────────────────────────────────────────
# Supabase (obligatorio)
# Project Settings → API en el dashboard de Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clave SECRETA: la "Secret key" (sb_secret_...) o la legacy "service_role".
# Solo se usa en el servidor. NUNCA exponer en el cliente ni commitearla.
# NO uses la "publishable key" (sb_publishable_...) acá: es pública y no sirve.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Panel de administración (obligatorio)
# ─────────────────────────────────────────────────────────────
# Contraseña para entrar a /admin
ADMIN_PASSWORD=cambiame-por-una-clave-larga
# Texto aleatorio largo para firmar la sesión (ej: salida de `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=cambiame-por-un-texto-aleatorio-largo

# ─────────────────────────────────────────────────────────────
# Email de aviso a las abogadas (opcional)
# Si no se completa, la consulta igual se guarda en Supabase; solo no se envía el email.
# Servicio: https://resend.com  (API Keys)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# A dónde llegan los avisos (podés poner varios separados por coma)
NOTIFY_EMAIL_TO=
# Remitente verificado en Resend (ej: consultas@tudominio.com)
NOTIFY_EMAIL_FROM=Estudio C&V <onboarding@resend.dev>
